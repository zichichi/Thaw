    "Double-click an empty area of the menu bar to show always-hidden menu bar items." : {
      "comment" : "Toggle that allows users to enable or disable the feature of showing always-hidden menu bar items by double-clicking an empty area of the menu bar.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einen leeren Bereich der Menüleiste doppelt anklicken, um immer versteckte Menüleisten-Einträge anzuzeigen."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik area kosong bar menu untuk menampilkan item bar menu selalu-tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fare doppio clic su un'area vuota della barra dei menu per visualizzare le voci della barra dei menu sempre nascoste."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーの空いている領域をダブルクリックすると、常に非表示のメニューバー項目が表示されます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique duas vezes em uma área vazia da barra de menus para exibir os itens sempre ocultos da barra de menus."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her zaman gizli menü çubuğu öğelerini göstermek için menü çubuğunda boş bir alana çift tıklayın."
          }
        }
      }
    },
    "Double-click for always-hidden" : {
      "comment" : "A toggle that allows users to enable always-hidden menu bar items by double-clicking an empty area of the menu bar.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
