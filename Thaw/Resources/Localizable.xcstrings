      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeige den Hintergrund der System-Menüleiste. Aktivieren, wenn ein dynamisches Hintergrundbild verwendet wird oder ‚Menüleiste > Menüleistenhintergrund anzeigen‘ in den Systemeinstellungen deaktivieren."
