    "Apply different settings based on the current system appearance." : {
      "comment" : "Label for a toggle that allows the user to choose whether to use different appearance settings based on the current system appearance.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
